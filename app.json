{
  "expo": {
    "name": "Swanthanam Flow",
    "slug": "swanthanam-flow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/image2.png",
    "scheme": "SwanthanamFlow",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png"
      },
      "softwareKeyboardLayoutMode": "resize",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.p1x.swanthanamflow"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/image1.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#E6FEED",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "135ad779-5d98-48bb-83ec-d09248c98ebf"
      }
    },
    "owner": "p1x"
  }
}
